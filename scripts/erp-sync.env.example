# erp-sync.env — GAS Web App credentials for ERP data sync
# Copy to ~/.nemoclaw/erp-sync.env and fill in your values
#
# GAS Web App URL (Deploy as Web App → copy URL)
GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOY_ID/exec

# API key (set in GAS script's KEY constant)
GAS_API_KEY=your-api-key-here

# Optional: override data directory (default: ~/Documents/SmarterERP/PUE/SHEET)
# ERP_DATA_DIR=/path/to/your/SHEET
